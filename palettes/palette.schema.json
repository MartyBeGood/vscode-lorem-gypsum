{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Theme Palette",
  "description": "Color palette mapping token roles to hex colors for a generated VSCode theme variant",
  "type": "object",
  "properties": {
    "comment":     { "type": "string", "format": "color-hex" },
    "string":      { "type": "string", "format": "color-hex" },
    "escape":      { "type": "string", "format": "color-hex" },
    "constant":    { "type": "string", "format": "color-hex" },
    "entityName":  { "type": "string", "format": "color-hex" },
    "invalid":     { "type": "string", "format": "color-hex" },
    "$schema": { "type": "string", "format": "uri-reference" }
  },
  "required": ["comment", "string", "escape", "constant", "entityName"],
  "additionalProperties": false
}
