[
  {
    "name": "Comments",
    "scope": [
      "comment",
      "punctuation.definition.comment"
    ],
    "settings": {
      "foreground": "$comment"
    }
  },
  {
    "name": "Strings",
    "scope": [
      "string",
      "string.regexp",
      "punctuation.definition.string",
      "constant.other.symbol"
    ],
    "settings": {
      "foreground": "$string"
    }
  },
  {
    "name": "Strings: Escape Sequences",
    "scope": "constant.character.escape",
    "settings": {
      "foreground": "$escape"
    }
  },
  {
    "name": "Numbers, Characters",
    "scope": [
      "constant.numeric",
      "constant.character",
      "constant.keyword",
      "constant",
      "variable.other.constant",
      "support.type.property-name"
    ],
    "settings": {
      "foreground": "$constant"
    }
  },
  {
    "name": "Global definitions",
    "scope": [
      "entity.name"
    ],
    "settings": {
      "foreground": "$entityName"
    }
  },
  {
    "name": "Invalid",
    "scope": "invalid",
    "settings": {
      "foreground": "$invalid"
    }
  }
]