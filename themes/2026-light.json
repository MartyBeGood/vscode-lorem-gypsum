  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#cf222e"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.regexp",
        "punctuation.definition.string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#116329"
      }
    },
    {
      "name": "Strings: Escape Sequences",
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#0550ae"
      }
    },
    {
      "name": "Numbers, Characters",
      "scope": [
        "constant.numeric",
        "constant.character",
        "constant.keyword",
        "constant",
        "variable.other.constant",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#AF00DB"
      }
    },
    {
      "name": "Global definitions",
      "scope": [
        "entity.name"
      ],
      "settings": {
        "foreground": "#0a3069"
      }
    },
    {
      "name": "Invalid",
      "scope": "invalid",
      "settings": {
        "foreground": "#cd3131"
      }
    }
  ],
  "semanticHighlighting": false
}
