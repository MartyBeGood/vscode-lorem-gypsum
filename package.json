{
  "name": "vscode-lorem-gypsum",
  "type": "module",
  "scripts": {
    "fetch-upstream": "node src/fetch-upstream.js",
    "extract-colors": "node src/extract-colors.js",
    "generate": "node src/generate-themes.js",
    "prebuild": "npm run fetch-upstream && npm run extract-colors && npm run generate",
    "build": "vsce package"
  },
  "displayName": "Lorem Gypsum",
  "description": "Default UI, Alabaster syntax, some tweaks to harmonize the two.",
  "icon": "./images/lorem-gypsum-logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/MartyBeGood/vscode-lorem-gypsum"
  },
  "license": "SEE LICENSE IN LICENSE.txt",
  "version": "1.0.0",
  "publisher": "MartyBeGood",
  "engines": {
    "vscode": "^1.110.0",
    "node": ">=18"
  },
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "default",
    "alabaster",
    "minimal",
    "syntax",
    "focus"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Lorem Gypsum Dark (Visual Studio)",
        "uiTheme": "vs-dark",
        "path": "./themes/dark_vs.json"
      },
      {
        "label": "Lorem Gypsum Light (Visual Studio)",
        "uiTheme": "vs",
        "path": "./themes/light_vs.json"
      },
      {
        "label": "Lorem Gypsum High Contrast",
        "uiTheme": "hc-black",
        "path": "./themes/hc_black.json"
      },
      {
        "label": "Lorem Gypsum High Contrast Light",
        "uiTheme": "hc-light",
        "path": "./themes/hc_light.json"
      },
      {
        "label": "Lorem Gypsum Dark+",
        "uiTheme": "vs-dark",
        "path": "./themes/dark_plus.json"
      },
      {
        "label": "Lorem Gypsum Light+",
        "uiTheme": "vs",
        "path": "./themes/light_plus.json"
      },
      {
        "label": "Lorem Gypsum Dark Modern",
        "uiTheme": "vs-dark",
        "path": "./themes/dark_modern.json"
      },
      {
        "label": "Lorem Gypsum Light Modern",
        "uiTheme": "vs",
        "path": "./themes/light_modern.json"
      },
      {
        "label": "Lorem Gypsum 2026 Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/2026-dark.json"
      },
      {
        "label": "Lorem Gypsum 2026 Light",
        "uiTheme": "vs",
        "path": "./themes/2026-light.json"
      }
    ]
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1"
  }
}
